# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Circle Configuration
# Your Circle API Key from the Developer Console (https://console.circle.com)
CIRCLE_API_KEY=TEST_API_KEY:your_circle_api_key

# Receipt scanning
RECEIPT_SCANNER_API_KEY=your_receipt_scanner_key
RECEIPT_SCANNER_MODEL=receipt-scanner-model

# ── Sign-in providers ─────────────────────────────────────────────────────
# Splitsy supports four sign-in methods. Configure whichever you want to enable;
# each is independent. Google and Email-OTP both resolve to the same email-keyed
# identity (refId "email:<addr>"), so a person who uses either shares one wallet.

# X (Twitter) OAuth 2.0 — Sign in with X (confidential client)
# From the X Developer Portal → your app → Keys and tokens → OAuth 2.0 Client ID and Secret.
X_CLIENT_ID=your_x_oauth2_client_id
X_CLIENT_SECRET=your_x_oauth2_client_secret
# Optional: pin the OAuth redirect origin (defaults to the request origin).
# Must match a Callback URI registered on the X app, e.g. https://splitsy.xyz
# X_OAUTH_REDIRECT_ORIGIN=https://splitsy.xyz

# Discord OAuth 2.0 — Sign in with Discord
# From the Discord Developer Portal → your app → OAuth2. Callback: /api/auth/discord/callback
DISCORD_CLIENT_ID=your_discord_oauth2_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth2_client_secret
# DISCORD_OAUTH_REDIRECT_ORIGIN=https://splitsy.xyz

# Google OAuth 2.0 — Sign in with Google
# From the Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (Web application). Authorized redirect URI: <origin>/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_oauth2_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth2_client_secret
# GOOGLE_OAUTH_REDIRECT_ORIGIN=https://splitsy.xyz

# Email-OTP — Sign in with a one-time code emailed via Resend (https://resend.com)
# EMAIL_FROM must be a verified sender on the Resend account. Requires the
# email_otps table (run schema-otp.sql in Supabase once).
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Splitsy <auth@yourdomain>

# Session signing secret for the Splitsy login cookie (min 32 chars).
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ── ERC-8004 Payment Reputation ──────────────────────────────────────────────
# Optional: Pinata JWT for uploading agent metadata to IPFS (full ERC-8004 compliance).
# Create a Pinata API key with "pinFileToIPFS" permission at https://app.pinata.cloud
# If not set, registration falls back to data: URIs (reputation still works, just
# without discoverable off-chain metadata).
PINATA_JWT=your_pinata_jwt_token
PINATA_GATEWAY=gateway.pinata.cloud

# Optional: Override Arc Testnet's pre-deployed ERC-8004 registries (only if redeployed).
# ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
# ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Splitsy Arc Testnet Contract Deployment
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
DEPLOYER_PRIVATE_KEY=0xyour_funded_arc_testnet_private_key
RECURRING_SETTLER_PRIVATE_KEY=0xyour_funded_arc_testnet_settler_private_key
RECURRING_SETTLER_SECRET=replace_with_a_long_random_bearer_secret
CRON_SECRET=replace_with_the_same_secret_if_your_host_uses_cron_secret
RECURRING_TEST_CYCLE_SECRET=optional_secret_to_show_test_cycle_in_ui
ARC_TESTNET_CHAIN_ID=5042002
ARC_TESTNET_EXPLORER_URL=https://testnet.arcscan.app
ARC_TESTNET_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_RECURRING_TAB_FACTORY_ADDRESS=0x556C119e587985b869A75dae95b82A65E1EccBD8
NEXT_PUBLIC_BILL_SPLIT_REGISTRY_ADDRESS=0x8103b385eC257CF2b2Bc91Bc1eC9AECBA244AB85

# Optional: Pimlico ERC-4337 bundler API key for the Circle Paymaster path, which
# lets a browser wallet with no native gas token pay source-chain bridge gas in
# USDC. Just the key — the per-chain URL is built from it. Leave unset to use
# Pimlico's public testnet endpoint (fine for dev). Get a key at dashboard.pimlico.io
NEXT_PUBLIC_PIMLICO_API_KEY=
